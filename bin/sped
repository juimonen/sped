#!/usr/bin/env node
'use strict'

const path = require('path')
const fs = require('fs')
const { createEDL, cut, paste, extractRegions } = require('../lib/edl')
const {
  EDLStore,
  getActiveProject, setActiveProject,
  getActiveTrack, setActiveTrack,
  getTracksMeta, setTrackMeta,
  listTracks, buildPlayPayload, signalUpdate
} = require('../lib/store')

const [,, command, ...args] = process.argv

function parseTime(s) {
  const v = parseFloat(s)
  if (isNaN(v)) { console.error('Invalid time: ' + s); process.exit(1) }
  return v
}

function requireProject() {
  const p = getActiveProject()
  if (!p) { console.error('No active project. Run: sped open <path>'); process.exit(1) }
  return p
}

function requireStore(projectPath, trackId) {
  const tid = trackId || getActiveTrack(projectPath)
  return { store: EDLStore.forTrack(projectPath, tid), trackId: tid }
}

function requireEDL(store) {
  const edl = store.read()
  if (!edl) { console.error('Track has no EDL yet. Run: sped import <file.wav>'); process.exit(1) }
  return edl
}

function fmt(t) {
  const m = Math.floor(t / 60)
  const s = (t % 60).toFixed(2).padStart(5, '0')
  return m + ':' + s
}

function signalPlay(projectPath) {
  const payload = buildPlayPayload(projectPath)
  const signalPath = path.join(projectPath, 'play.json')
  fs.writeFileSync(signalPath, JSON.stringify(payload, null, 2))
  return payload
}

function update(projectPath) {
  const payload = buildPlayPayload(projectPath)
  signalUpdate(projectPath, payload)
}

switch (command) {

  case 'open': {
    const projectPath = args[0]
    if (!projectPath) { console.error('Usage: sped open <path>'); process.exit(1) }
    const absPath = path.resolve(projectPath)
    const existed = fs.existsSync(absPath)
    fs.mkdirSync(absPath, { recursive: true })
    setActiveProject(absPath)
    if (existed && listTracks(absPath).length > 0) {
      const tracks = listTracks(absPath)
      console.log('Resumed project: ' + absPath)
      console.log('Tracks: ' + tracks.join(', ') + '  (active: ' + getActiveTrack(absPath) + ')')
    } else {
      console.log('Created project: ' + absPath)
      console.log('Now run: sped import <file.wav>')
    }
    break
  }

  case 'import': {
    // sped import <file.wav> [trackId] [position: start|end|<seconds>]
    const projectPath = requireProject()
    const file = args[0]
    if (!file) { console.error('Usage: sped import <file.wav> [track] [start|end|<t>]'); process.exit(1) }
    const absFile = path.resolve(file)
    if (!fs.existsSync(absFile)) { console.error('File not found: ' + absFile); process.exit(1) }

    const { getWavDuration } = require('../lib/wavduration')
    const duration = getWavDuration(absFile)
    if (!duration) { console.error('Could not read WAV header: ' + absFile); process.exit(1) }

    // Parse optional track and position args
    let trackId = getActiveTrack(projectPath)
    let position = 'end'  // default: append

    if (args[1] != null) {
      // If it looks like a number and > 10 it's probably a track id not a time
      // Convention: track ids are integers, position is 'start','end', or decimal
      if (args[1] === 'start' || args[1] === 'end' || args[1].includes('.')) {
        position = args[1]
      } else {
        trackId = args[1]
        if (args[2] != null) position = args[2]
      }
    }

    const store = EDLStore.forTrack(projectPath, trackId)
    const existing = store.read()

    let newRegions
    const newRegion = { file: absFile, offset: 0, duration, fadeIn: 0, fadeOut: 0 }

    if (!existing) {
      // First import to this track
      newRegions = [newRegion]
    } else if (position === 'end') {
      newRegions = [...existing.regions, newRegion]
    } else if (position === 'start') {
      newRegions = [newRegion, ...existing.regions]
    } else {
      // Insert at time t
      const t = parseFloat(position)
      newRegions = paste(existing ? existing.regions : [], [newRegion], t)
    }

    const edl = existing || { regions: [] }
    const idx = store.write({ ...edl, regions: newRegions })

    // Set this as active track
    setActiveTrack(projectPath, trackId)

    console.log('Imported ' + path.basename(file) + ' (' + duration.toFixed(3) + 's) -> track ' + trackId + ' EDL #' + idx)
    update(projectPath)
    break
  }

  case 'track': {
    // sped track           → show active track
    // sped track <id>      → set active track
    const projectPath = requireProject()
    if (args[0] == null) {
      console.log('Active track: ' + getActiveTrack(projectPath))
    } else {
      setActiveTrack(projectPath, args[0])
      console.log('Active track: ' + args[0])
    }
    break
  }

  case 'tracks': {
    const projectPath = requireProject()
    const tracks = listTracks(projectPath)
    const meta = getTracksMeta(projectPath)
    const active = getActiveTrack(projectPath)
    if (tracks.length === 0) { console.log('No tracks. Run: sped import <file.wav>'); break }
    console.log('Tracks:')
    tracks.forEach(id => {
      const store = EDLStore.forTrack(projectPath, id)
      const edl = store.read()
      const total = edl ? edl.regions.reduce((s, r) => s + (r.duration || 0), 0) : 0
      const m = meta[id] || {}
      const flags = (m.muted ? ' [muted]' : '') + (id === active ? ' *' : '')
      console.log('  track ' + id + ': ' + (edl ? edl.regions.length + ' region(s), ' + total.toFixed(3) + 's' : 'empty') + flags)
    })
    break
  }

  case 'mute': {
    const projectPath = requireProject()
    const trackId = args[0] || getActiveTrack(projectPath)
    setTrackMeta(projectPath, trackId, { muted: true })
    console.log('Muted track ' + trackId)
    update(projectPath)
    break
  }

  case 'unmute': {
    const projectPath = requireProject()
    const trackId = args[0] || getActiveTrack(projectPath)
    setTrackMeta(projectPath, trackId, { muted: false })
    console.log('Unmuted track ' + trackId)
    update(projectPath)
    break
  }

  case 'solo': {
    const projectPath = requireProject()
    const soloId = args[0] || getActiveTrack(projectPath)
    const tracks = listTracks(projectPath)
    tracks.forEach(id => setTrackMeta(projectPath, id, { muted: id !== soloId }))
    console.log('Solo track ' + soloId)
    update(projectPath)
    break
  }

  case 'unsolo': {
    const projectPath = requireProject()
    const tracks = listTracks(projectPath)
    tracks.forEach(id => setTrackMeta(projectPath, id, { muted: false }))
    console.log('All tracks unmuted')
    update(projectPath)
    break
  }

  case 'status': {
    const projectPath = requireProject()
    const active = getActiveTrack(projectPath)
    const { store, trackId } = requireStore(projectPath)
    const edl = requireEDL(store)
    const idx = store.currentIndex()
    console.log('Project: ' + projectPath + '  (track ' + trackId + ' active)')
    console.log('EDL #' + idx + ' - ' + edl.regions.length + ' region(s)')
    let cursor = 0
    edl.regions.forEach((r, i) => {
      const dur = r.duration != null ? r.duration.toFixed(3) : '?'
      console.log('  [' + i + '] ' + path.basename(r.file) + '  offset=' + r.offset.toFixed(3) + 's  dur=' + dur + 's  @ ' + cursor.toFixed(3) + 's')
      cursor += r.duration || 0
    })
    const total = edl.regions.reduce((s, r) => s + (r.duration || 0), 0)
    console.log('  Total: ' + total.toFixed(3) + 's')
    break
  }

  case 'copy': {
    const start = parseTime(args[0])
    const end = parseTime(args[1])
    if (end <= start) { console.error('end must be > start'); process.exit(1) }
    const slot = args[2] != null ? args[2] : '0'
    const projectPath = requireProject()
    const { store } = requireStore(projectPath)
    const edlIndex = store.currentIndex()
    store.writeSlot(slot, edlIndex, start, end)
    console.log('Slot ' + slot + ': [' + start.toFixed(3) + 's - ' + end.toFixed(3) + 's] (' + (end-start).toFixed(3) + 's)')
    break
  }

  case 'cut': {
    const start = parseTime(args[0])
    const end = parseTime(args[1])
    if (end <= start) { console.error('end must be > start'); process.exit(1) }
    const projectPath = requireProject()
    const { store } = requireStore(projectPath)
    const edl = requireEDL(store)
    const clipped = extractRegions(edl.regions, start, end)
    store.writeClipboard(clipped)
    const newRegions = cut(edl.regions, start, end)
    const idx = store.write({ ...edl, regions: newRegions })
    console.log('Cut ' + (end - start).toFixed(3) + 's -> EDL #' + idx)
    update(projectPath)
    break
  }

  case 'paste': {
    const t = parseTime(args[0])
    const projectPath = requireProject()
    const { store } = requireStore(projectPath)
    const edl = requireEDL(store)
    const clipboard = store.readClipboard()
    if (!clipboard) { console.error('Clipboard empty.'); process.exit(1) }
    const newRegions = paste(edl.regions, clipboard, t)
    const idx = store.write({ ...edl, regions: newRegions })
    const dur = clipboard.reduce((s, r) => s + r.duration, 0)
    console.log('Pasted ' + dur.toFixed(3) + 's at ' + t.toFixed(3) + 's -> EDL #' + idx)
    update(projectPath)
    break
  }

  case 'slots': {
    const projectPath = requireProject()
    const { store } = requireStore(projectPath)
    const slots = store.listSlots()
    if (slots.length === 0) { console.log('No slots.'); break }
    console.log('Slots:')
    slots.forEach(s => {
      console.log('  [' + s.slot + '] EDL #' + s.edlIndex + '  ' + s.start.toFixed(3) + 's - ' + s.end.toFixed(3) + 's  (' + (s.end - s.start).toFixed(3) + 's)')
    })
    break
  }

  case 'join': {
    if (args.length === 0) { console.error('Usage: sped join <slot> [slot...]'); process.exit(1) }
    const projectPath = requireProject()
    const { store } = requireStore(projectPath)
    const edl = requireEDL(store)
    const newRegions = []
    for (const slot of args) {
      const regions = store.resolveSlot(slot)
      if (!regions) { console.error('Slot ' + slot + ' not found.'); process.exit(1) }
      newRegions.push(...regions)
      console.log('  slot ' + slot + ': ' + regions.reduce((s,r) => s+r.duration, 0).toFixed(3) + 's')
    }
    const idx = store.write({ ...edl, regions: newRegions })
    const total = newRegions.reduce((s, r) => s + r.duration, 0)
    console.log('Joined ' + args.length + ' slot(s) -> ' + total.toFixed(3) + 's -> EDL #' + idx)
    update(projectPath)
    break
  }

  case 'undo': {
    const projectPath = requireProject()
    const { store, trackId } = requireStore(projectPath)
    if (store.undo()) {
      const edl = store.read()
      console.log('Undo track ' + trackId + ' -> EDL #' + store.currentIndex() + ' (' + edl.regions.length + ' region(s))')
      update(projectPath)
    }
    break
  }

  case 'play': {
    const projectPath = requireProject()

    // Optional region filter for active track
    const startTime = args[0] != null ? parseTime(args[0]) : null
    const endTime   = args[1] != null ? parseTime(args[1]) : null

    let payload = buildPlayPayload(projectPath)

    // If region specified, filter active track to that region
    if (startTime != null || endTime != null) {
      const activeTrack = getActiveTrack(projectPath)
      payload.tracks = payload.tracks.map(t => {
        if (t.id !== activeTrack) return t
        const total = t.regions.reduce((s, r) => s + (r.duration || 0), 0)
        const s = startTime != null ? startTime : 0
        const e = endTime   != null ? endTime   : total
        return { ...t, regions: extractRegions(t.regions, s, e) }
      })
    }

    const signalPath = path.join(projectPath, 'play.json')
    fs.writeFileSync(signalPath, JSON.stringify(payload, null, 2))

    const totalDur = Math.max(...payload.tracks.map(t =>
      t.muted ? 0 : t.regions.reduce((s, r) => s + (r.duration || 0), 0)
    ))

    const statusPath = path.join(projectPath, 'playback_status.json')
    if (fs.existsSync(statusPath)) fs.unlinkSync(statusPath)

    process.stdout.write('\r\u25b6 0:00.00 / ' + fmt(totalDur) + '  [Ctrl+C to stop]')

    const startedAt = Date.now()
    const poll = setInterval(() => {
      let currentTime
      try {
        const status = JSON.parse(fs.readFileSync(statusPath, 'utf8'))
        if (Date.now() - status.ts < 2000) {
          currentTime = status.currentTime
          if (!status.playing && status.currentTime > 0) {
            clearInterval(poll); process.stdout.write('\n'); process.exit(0)
          }
        }
      } catch (e) {}
      if (currentTime == null) currentTime = (Date.now() - startedAt) / 1000
      process.stdout.write('\r\u25b6 ' + fmt(currentTime) + ' / ' + fmt(totalDur) + '  [Ctrl+C to stop]')
      if (currentTime >= totalDur - 0.1) {
        clearInterval(poll); process.stdout.write('\n'); process.exit(0)
      }
    }, 100)

    process.on('SIGINT', () => {
      clearInterval(poll)
      const http = require('http')
      http.get('http://localhost:3000/stop', () => {}).on('error', () => {})
      process.stdout.write('\n')
      setTimeout(() => process.exit(0), 100)
    })
    break
  }

  case 'active': {
    const p = getActiveProject()
    console.log(p ? 'Active project: ' + p : 'No active project.')
    break
  }

  case 'help':
  default: {
    console.log([
      'sped-e — non-destructive multitrack audio editor',
      '',
      '  sped open <path>                open or create a project',
      '  sped import <file> [track] [start|end|<t>]  import audio to track',
      '  sped track                      show active track',
      '  sped track <id>                 set active track',
      '  sped tracks                     list all tracks',
      '  sped mute [track]               mute a track',
      '  sped unmute [track]             unmute a track',
      '  sped solo [track]               solo a track',
      '  sped unsolo                     unmute all tracks',
      '',
      '  sped status                     show active track EDL',
      '  sped copy <start> <end> [slot]  copy to slot (default 0)',
      '  sped slots                      list copy slots',
      '  sped join <slot> [slot...]      build new EDL from slots',
      '  sped cut  <start> <end>         cut section out',
      '  sped paste <t>                  paste at position',
      '  sped undo                       revert active track EDL',
      '',
      '  sped play                       play all tracks mixed',
      '  sped play <start> <end>         play region of active track',
      '  sped active                     show active project',
      '',
      'All times in seconds.',
    ].join('\n'))
    break
  }
}
