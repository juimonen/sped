<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>sped2</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/xterm@5.3.0/css/xterm.min.css">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0 }
    body {
      background: #1a1a1a;
      color: #e0e0e0;
      font-family: 'SF Mono', 'Fira Code', monospace;
      height: 100vh;
      display: flex;
      flex-direction: column;
    }
    #header {
      background: #111;
      border-bottom: 1px solid #333;
      padding: 8px 16px;
      display: flex;
      align-items: center;
      gap: 16px;
      flex-shrink: 0;
    }
    #header h1 {
      font-size: 14px;
      color: #888;
      font-weight: normal;
      letter-spacing: 2px;
    }
    #status {
      font-size: 12px;
      color: #555;
    }
    #status.playing { color: #4ec9b0 }
    #status.connected { color: #4ec9b0 }

    #main {
      display: flex;
      flex: 1;
      min-height: 0;
    }

    /* Left: terminal */
    #terminal-panel {
      width: 50%;
      border-right: 1px solid #333;
      display: flex;
      flex-direction: column;
    }
    #terminal-label {
      padding: 6px 12px;
      font-size: 11px;
      color: #555;
      border-bottom: 1px solid #222;
      flex-shrink: 0;
    }
    #terminal {
      flex: 1;
      padding: 4px;
      overflow: hidden;
    }

    /* Right: playback */
    #playback-panel {
      width: 50%;
      display: flex;
      flex-direction: column;
      padding: 16px;
      gap: 16px;
    }
    #playback-label {
      font-size: 11px;
      color: #555;
    }

    /* Timeline / waveform area */
    #timeline {
      flex: 1;
      background: #111;
      border: 1px solid #2a2a2a;
      border-radius: 4px;
      position: relative;
      overflow: hidden;
      min-height: 120px;
    }
    #timeline canvas {
      width: 100%;
      height: 100%;
    }

    /* Regions display */
    #regions {
      display: flex;
      flex-direction: column;
      gap: 4px;
      max-height: 200px;
      overflow-y: auto;
    }
    .region {
      background: #1e3a4a;
      border: 1px solid #2a5a6a;
      border-radius: 3px;
      padding: 4px 8px;
      font-size: 11px;
      display: flex;
      gap: 12px;
      color: #8cc8d8;
    }
    .region .file { color: #4ec9b0; }
    .region .time { color: #666; }

    /* Transport */
    #transport {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }
    #play-btn {
      background: #2a4a3a;
      border: 1px solid #3a6a4a;
      color: #4ec9b0;
      padding: 6px 16px;
      border-radius: 3px;
      cursor: pointer;
      font-family: inherit;
      font-size: 13px;
    }
    #play-btn:hover { background: #3a5a4a }
    #stop-btn {
      background: #3a2a2a;
      border: 1px solid #5a3a3a;
      color: #c07070;
      padding: 6px 16px;
      border-radius: 3px;
      cursor: pointer;
      font-family: inherit;
      font-size: 13px;
    }
    #stop-btn:hover { background: #4a3a3a }
    #time-display {
      font-size: 13px;
      color: #666;
      font-variant-numeric: tabular-nums;
    }
    #no-edl {
      color: #444;
      font-size: 12px;
      text-align: center;
      padding: 32px;
    }
  </style>
</head>
<body>

<div id="header">
  <h1>SPED2</h1>
  <span id="status">connecting...</span>
</div>

<div id="main">
  <div id="terminal-panel">
    <div id="terminal-label">shell</div>
    <div id="terminal"></div>
  </div>

  <div id="playback-panel">
    <div id="playback-label">playback</div>
    <div id="timeline">
      <canvas id="timeline-canvas"></canvas>
    </div>
    <div id="regions">
      <div id="no-edl">run <code>sped2 play</code> in the shell to load</div>
    </div>
    <div id="transport">
      <button id="play-btn">▶ play</button>
      <button id="stop-btn">■ stop</button>
      <span id="time-display">0:00.000</span>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/xterm@5.3.0/lib/xterm.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xterm-addon-fit@0.8.0/lib/xterm-addon-fit.min.js"></script>
<script src="js/player.js"></script>
<script src="js/app.js"></script>
</body>
</html>
